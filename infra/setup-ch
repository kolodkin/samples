#!/usr/bin/env bash
set -euo pipefail

CH_VERSION="${CH_VERSION:-latest}"

echo "Installing ClickHouse (${CH_VERSION})..."
if ! command -v clickhouse &>/dev/null; then
    DEBIAN_FRONTEND=noninteractive
    apt-get install -y -qq apt-transport-https ca-certificates gpg >/dev/null 2>&1
    curl -fsSL 'https://packages.clickhouse.com/rpm/lts/repodata/repomd.xml.key' \
        | gpg --dearmor -o /usr/share/keyrings/clickhouse-keyring.gpg
    echo "deb [signed-by=/usr/share/keyrings/clickhouse-keyring.gpg] https://packages.clickhouse.com/deb stable main" \
        > /etc/apt/sources.list.d/clickhouse.list
    apt-get update -qq >/dev/null 2>&1
    apt-get install -y -qq clickhouse-server clickhouse-client >/dev/null 2>&1
fi

echo "Starting ClickHouse server..."
clickhouse server &>/dev/null &

echo "Waiting for ClickHouse to start..."
for i in {1..30}; do
    if curl -sf http://localhost:8123/ping &>/dev/null; then
        echo "ClickHouse $(clickhouse client -q 'SELECT version()') is ready!"
        exit 0
    fi
    sleep 1
done

echo "ERROR: ClickHouse failed to start within 30 seconds"
exit 1
